{
  "name": "credx-backend",
  "version": "1.0.0",
  "description": "Smart Job Matching Dashboard — NestJS API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main",
    "db:setup": "prisma generate && prisma migrate dev --name init && prisma db seed",
